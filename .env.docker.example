# Host port exposed by Docker Compose.
PORT=52389

# Docker image used by Docker Compose. Override this to pin a release tag.
WEB2GEM_IMAGE=ghcr.io/guardinary/web2gem-account-pool:latest

# Optional auth. Empty API_KEYS disables authentication.
API_KEYS=

# Optional account-pool admin auth. Admin endpoints fail closed when this is
# empty. Use one strong key and do not use placeholder values such as changeme.
ADMIN_KEY=

# Required Docker D1 HTTP binding for public Gemini generation. Set all three
# together to inject GEMINI_DB; partial configuration fails startup.
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# Docker self-hosting should keep socket transport disabled unless the runtime
# provides cloudflare:sockets.
UPSTREAM_SOCKET=false

# Optional runtime overrides.
GEMINI_BL=
GEMINI_ORIGIN=
DEFAULT_MODEL=
RETRY_ATTEMPTS=
RETRY_DELAY_SEC=
REQUEST_TIMEOUT_SEC=
REQUEST_BODY_MAX_BYTES=67108864
LOG_REQUESTS=
CURRENT_INPUT_FILE_ENABLED=
CURRENT_INPUT_FILE_MIN_BYTES=
CURRENT_INPUT_FILE_NAME=
CURRENT_TOOLS_FILE_NAME=
GENERIC_FILE_UPLOAD_MAX_BYTES=
