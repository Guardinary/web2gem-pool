# Normalize text files to LF in both the repository and working tree.
* text=auto eol=lf

# Windows command scripts require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Trellis framework tooling is not application source. Keep it visible in
# diffs while excluding it from GitHub language statistics.
.trellis/scripts/** linguist-vendored=true

# Generated sources should not skew language statistics. The embedded admin
# bundle is a single generated line, so suppress its unreviewable text diff.
src/generated/** linguist-generated=true
src/generated/admin-ui.ts -diff
worker-configuration.d.ts linguist-generated=true

# Images and documents.
*.avif binary
*.bmp binary
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.pdf binary
*.png binary
*.webp binary

# Fonts and compiled web assets.
*.eot binary
*.otf binary
*.ttf binary
*.wasm binary
*.woff binary
*.woff2 binary

# Audio and video.
*.mp3 binary
*.mp4 binary
*.ogg binary
*.wav binary
*.webm binary

# Archives and compressed assets.
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.zip binary
